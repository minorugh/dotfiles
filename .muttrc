############################################################
# Neomutt Configuration  2024.10.10
# ~/.muttrc
# @author Minoru Yamada <minorugh@gmail.com>

# Sources for Auth Configuration ---------------------------
source "~/.env_source/.mutt/password.rc"

# For japanese Environment
# see "https://emaillab.org/mutt/1.4/doc/usage-japanese.ja.html#id2432623"
set send_charset="iso-2022-jp:utf-8"
set thorough_search=yes    ## enable body search in Japanese
set rfc2047_parameters=yes ## filename for japanese

# Basic Configuration --------------------------------------
set ssl_starttls = yes
set ssl_force_tls = yes
set folder = "imaps://imap.gmail.com:993"
set spoolfile = "+INBOX"
set imap_check_subscribed
set hostname = gmail.com
set mail_check = 60
set timeout = 15
set imap_keepalive = 240
set imap_idle = yes
unset imap_passive
set history_file = ~/.mutt/history 
# set postponed = "+[Gmail]/Drafts"
set trash = "+[Gmail]/Trash"
set record = "+[Gmail]/Sent Mail"
set header_cache = "~/.mutt/cache/headers"
set message_cachedir = "~/.mutt/cache/bodies"
set certificate_file= "~/.mutt/certificates"
set signature = "~/.env_source/.mutt/signature"
set move = no
# set delete = yes
set include
set sort = 'threads'
set sort_aux = 'reverse-last-date-received'
set auto_tag = yes
ignore "Authentication-Results:"
ignore "DomainKey-Signature:"
ignore "DKIM-Signature:"
hdr_order Date From To Cc
set pager_index_lines=8
bind editor ^T complete
bind editor <space> noop

# mailcap
set mailcap_path = "~/.mutt/mailcap"

# Print Command
set print_command = "nkf -em | e2ps -size 11 -head muttmail | lpr"

# notify-send ----------------------------------------------
set new_mail_command="notify-send --icon=mail-message-new 'New Email' '%n new messages, %u unread.' &"

# Open URL using w3m ---------------------------------------
macro index,pager u ": unset wait_key; set pipe_decode\n|w3m\n: \
set wait_key; unset pipe_decode\n" "call w3m to extract URLs out of a message"
# macro index,pager \cb ": unset wait_key; set pipe_decode\n|w3m\n: \
# set wait_key; unset pipe_decode\n" "call w3m to extract URLs out of a message"

# Change the following line to a different editor you prefer.
set editor="emacsclient"
#set editor="vim"

# addressbook use Abook
set query_command= "abook --mutt-query '%s'"
macro index,pager  a "<pipe-message>abook --add-email-quiet<return>" "Add this sender to Abook"
bind editor        <Tab> complete-query

# Sidebar Patch --------------------------------------------
set sidebar_format   = "%B%?F? [%F]?%* %?N?%N/?%S"
# set sidebar_visible = yes
set sidebar_width    = 28

# Status Bar -----------------------------------------------
set status_chars  = " *%A"
set status_format = "---[ Folder: %f ]---[%r%m messages%?n? (%n new)?%?d? (%d to delete)?%?t? (%t tagged)? ]---%>-%?p?( %p postponed )?---"

# Index View Options ---------------------------------------
set index_format="%4C %Z %<[y?%<[d?%[%H:%M           ]&%[%m/%d (%a) %H:%M]>&%[%Y/%m/%d %H:%M]> %-15.15L (%?l?%4l&%4c?) %s"
set sort = threads                         # like gmail
set sort_aux = reverse-last-date-received  # like gmail
set uncollapse_jump                        # don't collapse on an unread message
set sort_re                                # thread based on regex
set reply_regexp = "^(([Rr][Ee]?(\[[0-9]+\])?: *)?(\[[^]]+\] *)?)*"

# Pager View Options ---------------------------------------
set pager_index_lines =  8 # number of index lines to show
set pager_context = 3      # number of context lines to show
set pager_stop             # don't go to next message automatically
set menu_scroll            # scroll in menus
set tilde                  # show tildes like in vim
unset markers              # no ugly plus signs
set quote_regexp = "^( {0,4}[>|:#%]| {0,4}[a-z0-9]+[>|]+)+"
alternative_order text/plain text/enriched text/html

# Saner copy/move dialogs
macro index C "<copy-message>?<toggle-mailboxes>" "copy a message to a mailbox"
macro index M "<save-message>?<toggle-mailboxes>" "move a message to a mailbox"

# Sidebar Navigation ---------------------------------------
bind index,pager ]   sidebar-next
bind index,pager [   sidebar-prev
bind index,pager \^  sidebar-toggle-visible
bind index,pager o sidebar-open

# Pager Navigation（追加）
bind pager j next-line
bind pager k previous-line

# Index Key Bindings ---------------------------------------
bind index,attach g first-entry       # Go to first entry
bind index,attach G last-entry        # Go to last entry
bind index,pager  b previous-page     # Go to previous page
macro index,pager S "<change-folder>=INBOX<enter><refresh>" "IMAPの再接続とフォルダの開き直し"

# index画面でqを押したらウィンドウを最小化（Xfce用）
# set quit = yes
unset wait_key
macro index q "<shell-escape>wmctrl -c 'NeoMutt Mail' > /dev/null 2>&1<enter>" "close window"

# Rキーで tmux の mail ペインを再生成し、NeoMutt を再起動
macro index,pager R "<shell-escape>tmux respawn-pane -k -t mail:0.0<Enter>"

# ====================================================================
# Color settings for mutt --------------------------------
# ====================================================================
# source ~/.mutt/dracula.muttrc
# Iceberg Inspired Theme for NeoMutt (Dracula background)
# 全体のデフォルト（背景：Dracula #282a36）
color normal        color252        default
# エラーとステータス・インジケータ
color error         color110        default
color message       color110        default
color status        color245        default
color indicator     color231        color68
color prompt        color150        default
# インデックス（メール一覧）の配色
color index         color252        default        ~A
color index         color150        default        ~N
color index         color110        default        ~O
color index         color216        default        ~F
color index         color243        default        ~D
# メッセージヘッダー
color hdrdefault    color243        default
color header        color110        default        "^(From|Subject):"
color header        color150        default        "^Date:"
# メール本文・引用
color quoted        color109        default
color quoted1       color244        default
color quoted2       color150        default
color signature     color243        default
color attachment    color216        default
# メインURLや検索ヒット
color search        default        color150
color body          color110        default        "(https?|ftp|news)://[^>\s]+"
color body          color110        default        "[-a-z_0-9.]+@[-a-z_0-9.]+"
# サイドバー
color sidebar_divider color237      default
color sidebar_new     color150      default

# カラーチャート表示コマンド（ターミナルで実行）
# python3 -c "
# for i in range(0, 256):
#     print(f'\033[48;5;{i}m {i:3d} \033[0m', end='')
#     if (i + 1) % 16 == 0:
#         print()
# "

# .muttrc ends here
############################################################

