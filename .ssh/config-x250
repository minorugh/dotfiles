# for x250
Host * 
	ForwardX11 no
	ServerAliveInterval 60
	Cipher arcfour256
	GSSAPIAuthentication no
	AddressFamily inet
  
Host xsrv
	HostName minorugh.xsrv.jp
	Port     10022
	User     minorugh
	Identityfile ~/.ssh/id_rsa

Host github.com
	HostName github.com
	User     git
    Port 22
    Identityfile ~/.ssh/github_id_rsa

Host gist.github.com
	HostName gist.github.com
	User     git
    Port 22
    Identityfile ~/.ssh/github_id_rsa

