#------------------------------------------------------------
# X resources
#------------------------------------------------------------
if [ -f ~/.Xresources ]; then
    xrdb -merge ~/.Xresources
fi

#------------------------------------------------------------
# X keyboard settings
#------------------------------------------------------------
# X セッション情報をログに残す（デバッグ用・動作には影響なし）
echo "$(date) xprofile start (DISPLAY=$DISPLAY, SESSION=$XDG_SESSION_TYPE)" >> "$HOME/.xprofile.log"

# キーボードを日本語配列に設定し、CapsLockをCtrlに変更
# ※ setxkbmap は XKB レイヤーを初期化するため、必ず xmodmap より先に実行する
setxkbmap -layout jp -option ctrl:nocaps

# .Xmodmap が存在する場合は読み込む
# setxkbmap の直後に実行することで、XKB の初期化を上書きして反映させる
#
# 主な設定内容：
#   - keycode 107 (ThinkPad PrtSc) → Alt_R として使用
#   - keycode  97 (日本語「ろ」キー) → _ および \ を割り当て
#   - keycode 191-195 (Keychron QMK 単押し送出) → F13-F17 として命名
#     ※ F13-F17 は xmodmap で名前をつけないと 0xef8d 等の未定義 keysym になり
#        Emacs・Xfce どちらも認識できないため必須
if [ -f ~/.Xmodmap ]; then
    xmodmap ~/.Xmodmap
fi

# XKB 変化イベントを監視して xmodmap を自動再適用するウォッチャー
#
# 目的：
#   以下のいずれかが発生すると XKB がリセットされ xmodmap の設定が失われる。
#     - ThinkPad 内蔵キーボードを操作したとき（外部キーボードとの競合）
#     - スリープ復帰後
#     - IME 等が XKB を上書きしたとき
#   _XKB_RULES_NAMES プロパティの変化を xprop で監視し、
#   変化を検知したら 0.3 秒待って（競合状態を回避）xmodmap を再適用する。
#
# 備考：
#   - イベント駆動のため常時ポーリングより遥かに軽量
#   - 単独では失速を取りこぼす場合があることが判明しているため
#     cron による毎分実行と併用して多重防御とする
#   - Xfce4 セッション終了時にプロセスも自動終了する
(xprop -root -spy _XKB_RULES_NAMES | while read -r _; do
    sleep 0.3 && xmodmap ~/.Xmodmap
done) &

#------------------------------------------------------------
# Screen saver / DPMS
#------------------------------------------------------------
# Mesa25 + Intel UHD 630 環境でブランク復帰時にフリッカが発生するため
# Xの自動ブランクだけ無効化する。
# DPMSは残して power-menu.sh の「xset dpms force off」による手動オフを維持する。
xset s off

#------------------------------------------------------------
# SSH agent (keychain)
#------------------------------------------------------------
# systemd ユーザーセッションへ SSH agent 環境変数を伝える
dbus-update-activation-environment --systemd SSH_AUTH_SOCK SSH_AGENT_PID

# keychain が保存した SSH agent 環境を読み込む
if [ -f ~/.keychain/$(hostname)-sh ]; then
    source "$HOME/.keychain/$(hostname)-sh"
fi
