# ===== Thunderbird restore (unique targets) =====

.PHONY: tb-install tb-restore tb-restore-archive

TB_DIR := $(HOME)/.thunderbird
TB_BACKUP_BASE := $(HOME)/Dropbox/backup/thunderbird
TB_LATEST := $(TB_BACKUP_BASE)/latest
TB_ARCHIVE := $(TB_BACKUP_BASE)/archive

tb-install: ## Thunderbird インストール
	sudo apt update
	sudo apt install -y thunderbird

tb-restore: ## Thunderbird を latest から復元
	@if pgrep thunderbird > /dev/null; then \
		echo "[ERROR] Thunderbird is running."; \
		exit 1; \
	fi
	rm -rf $(TB_DIR)
	rsync -av $(TB_LATEST)/ $(TB_DIR)/
	chmod -R 700 $(TB_DIR)
	@echo "[OK] Thunderbird restored from latest."

tb-restore-archive: ## アーカイブから復元 FILE=xxx.tar.gz
	@if [ -z "$(FILE)" ]; then \
		echo "Usage: make tb-restore-archive FILE=xxxx.tar.gz"; \
		exit 1; \
	fi
	@if pgrep thunderbird > /dev/null; then \
		echo "[ERROR] Thunderbird is running."; \
		exit 1; \
	fi
	rm -rf $(TB_DIR)
	tar -xzf $(TB_ARCHIVE)/$(FILE) -C $(HOME)
	chmod -R 700 $(TB_DIR)
	@echo "[OK] Thunderbird restored from archive."
